{
  "name": "cloth-to-go-server",
  "version": "0.1.0",
  "private": true,
  "description": "API backend de CLOTH TO GO (Fastify + Prisma + SQLite).",
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "node src/server.js",
    "start": "node src/server.js",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:reset": "node prisma/reset-db.js && prisma db push && node prisma/seed.js",
    "test": "node --test"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@prisma/client": "^6.1.0",
    "fastify": "^5.2.0"
  },
  "devDependencies": {
    "prisma": "^6.1.0"
  }
}
