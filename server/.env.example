# Copia este archivo a .env y ajusta si hace falta.
# SQLite en desarrollo: un archivo local relativo a /prisma.
DATABASE_URL="file:./dev.db"

# Puerto del servidor.
PORT=3000

# Orígenes autorizados a leer la API, separados por comas.
# Vacío o ausente = se refleja cualquier origen (solo desarrollo).
# Producción, por ejemplo:  CORS_ORIGINS="https://clothtogo.app"
# CORS_ORIGINS="http://localhost:8000"

# Client ID de Google Cloud Console usado para verificar el ID token en
# POST /api/auth/google (audience). Debe ser EXACTAMENTE el mismo que usa el
# frontend en js/auth.js (GOOGLE_CLIENT_ID), o la verificación rechaza el token.
GOOGLE_CLIENT_ID="115840486389-f3vitcouhua5eckn3grn1gk9kqb7ccjs.apps.googleusercontent.com"
