// Esquema de la base de CLOTH TO GO.
// SQLite en desarrollo/testeo; para producción se cambia el provider a
// "postgresql" y la DATABASE_URL, sin tocar el código de la app.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Prenda del catálogo. Refleja los campos que ya usa el frontend (js/data.js).
/// Segunda mano y única: `disponibles` es 1 por defecto.
/// No guarda precio ni depósito: ambos se derivan de `value` (coste de
/// reposición) mediante rentalPrice()/depositFor() en js/data.js.
model Product {
  id          Int    @id
  name        String
  cat         String
  value       Float
  stars       Int
  size        String
  disponibles Int    @default(1)
  material    String
  weightKg    Float
  img         String
  desc        String

  @@map("products")
}

/// Usuario autenticado con Google. `googleSub` es el identificador estable
/// que Google garantiza (el email puede cambiar; el sub no). Se registra
/// (upsert) la primera vez que /api/auth/google verifica su ID token, y se
/// actualiza en cada login por si el nombre/foto cambiaron en Google.
model User {
  id        Int      @id @default(autoincrement())
  googleSub String   @unique
  email     String
  name      String
  picture   String?
  createdAt DateTime @default(now())

  @@map("users")
}
